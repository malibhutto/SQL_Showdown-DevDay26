# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/query_quest

# Auth
JWT_SECRET=replace_with_a_secure_random_secret
JWT_EXPIRES_IN=24h

# Admin
ADMIN_SECRET=replace_with_admin_secret

# OneCompiler / RapidAPI
RAPIDAPI_KEY=replace_with_rapidapi_key
RAPIDAPI_HOST=onecompiler-apis.p.rapidapi.com
ONECOMPILER_URL=https://onecompiler-apis.p.rapidapi.com/api/v1/run

# Frontend origin
FRONTEND_URL=http://localhost:5173

# Rate limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_RUN=30
RATE_LIMIT_MAX_SUBMIT=20
